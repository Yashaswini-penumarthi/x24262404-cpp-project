option_settings:
  aws:elasticbeanstalk:container:python:
    WSGIPath: agro_market.wsgi:application
  aws:elasticbeanstalk:environment:proxy:staticfiles:
    /static: staticfiles

files:
  "/etc/nginx/conf.d/proxy.conf":
    mode: "644"
    owner: "root"
    group: "root"
    content: |
      client_max_body_size 100M;

files:
  "/etc/nginx/conf.d/media.conf":
    mode: "000644"
    owner: root
    group: root
    content: |
      location /media/ {
          alias /var/app/current/media/;
      }